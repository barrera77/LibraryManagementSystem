@model Borrowing

@{
    ViewData["Title"] = "Edit Borrowing";
}

<h2>Edit Borrowing</h2>

<form asp-action="Edit" method="post">
    <input type="hidden" asp-for="Id" />
    <input type="hidden" asp-for="BorrowDate" />

    <div class="row">
        <div class="col-md-6">
            <div class="form-group mb-3">
                <label asp-for="BookId" class="form-label">Select Book</label>
                <select asp-for="BookId" class="form-control" asp-items="ViewBag.Books">
                    <option value="">-- Select a Book --</option>
                </select>
                <span asp-validation-for="BookId" class="text-danger"></span>
            </div>

            <div class="form-group mb-3">
                <label asp-for="ReaderId" class="form-label">Select Reader</label>
                <select asp-for="ReaderId" class="form-control" asp-items="ViewBag.Readers">
                    <option value="">-- Select a Reader --</option>
                </select>
                <span asp-validation-for="ReaderId" class="text-danger"></span>
            </div>
        </div>

        <div class="col-md-6">
            <div class="form-group mb-3">
                <label asp-for="Status" class="form-label"></label>
                <select asp-for="Status" class="form-control">
                    <option value="Active">Active</option>
                    <option value="Returned">Returned</option>
                    <option value="Overdue">Overdue</option>
                </select>
                <span asp-validation-for="Status" class="text-danger"></span>
            </div>

            <div class="form-group mb-3">
                <label asp-for="ReturnDate" class="form-label"></label>
                <input asp-for="ReturnDate" type="datetime-local" class="form-control" />
                <span asp-validation-for="ReturnDate" class="text-danger"></span>
            </div>

            <div class="form-group mb-3">
                <label asp-for="OverdueDays" class="form-label"></label>
                <input asp-for="OverdueDays" type="number" class="form-control" />
                <span asp-validation-for="OverdueDays" class="text-danger"></span>
            </div>
        </div>
    </div>

    <div class="form-group mt-3">
        <button type="submit" class="btn btn-success">Save</button>
        <a asp-action="Index" class="btn btn-secondary">Back to List</a>
    </div>
</form>

@section Scripts {
    <script src="https://cdn.jsdelivr.net/npm/jquery@3.6.0/dist/jquery.min.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/jquery-validation@1.19.5/dist/jquery.validate.min.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/jquery-validation-unobtrusive@3.2.12/dist/jquery.validate.unobtrusive.min.js"></script>
}
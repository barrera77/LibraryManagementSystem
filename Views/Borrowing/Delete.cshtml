@model Borrowing

@{
    ViewData["Title"] = "Delete Borrowing";
}

<h2>Delete Borrowing</h2>

<h3 class="text-danger">Are you sure you want to delete this borrowing record?</h3>

<div class="card">
    <div class="card-body">
        <dl class="row">
            <dt class="col-sm-3">Book</dt>
            <dd class="col-sm-9">@ViewBag.BookTitle</dd>

            <dt class="col-sm-3">Reader</dt>
            <dd class="col-sm-9">@ViewBag.ReaderName</dd>

            <dt class="col-sm-3">Borrow Date</dt>
            <dd class="col-sm-9">@Model.BorrowDate.ToString("yyyy-MM-dd HH:mm")</dd>

            <dt class="col-sm-3">Status</dt>
            <dd class="col-sm-9">@Model.Status</dd>

            <dt class="col-sm-3">Overdue Days</dt>
            <dd class="col-sm-9">@Model.OverdueDays</dd>
        </dl>
    </div>
</div>

<form asp-action="Delete" method="post" class="mt-3">
    <input type="hidden" asp-for="Id" />
    <button type="submit" class="btn btn-danger">Delete</button>
    <a asp-action="Index" class="btn btn-secondary">Cancel</a>
</form>